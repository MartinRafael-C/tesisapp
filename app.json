{
  "expo": {
    "name": "tesisapp",
    "slug": "tesisapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ImagenSplash.png",
    "scheme": "tesisapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/ImagenSplash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/ImagenSplash.png"
      },
      "package": "com.anonymous.tesisapp",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "TU_PROJECT_ID_AQUÍ"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ImagenSplash.png",
          "color": "#ffffff"
        }
      ]
    ]
  }
}