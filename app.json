{
  "expo": {
    "name": "Oratorio Digital",
    "slug": "tesisapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ImagenSplash.png", 
    "scheme": "tesisapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ImagenSplash.png",
        "backgroundColor": "#000000"
      },
      "package": "com.tuusuario.oratoriodigital",
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "splash": {
      "image": "./assets/images/ImagenSplash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/ImagenSplash.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ImagenSplash.png",
          "color": "#008080"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e2eeb50b-53a5-4065-b37e-ae5ebfc57ddb"
      }
    }
  }
}